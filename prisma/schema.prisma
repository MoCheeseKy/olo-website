// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  category     String
  image        String
  description  String   @db.Text
  width        String?
  length       String?
  material     String?
  lubricant    String?
  shopeeUrl    String?  @map("shopee_url")
  tokopediaUrl String?  @map("tokopedia_url")
  typeId       Int?     @map("type_id")
  type         ProductType? @relation(fields: [typeId], references: [id])
  isBestProduct Boolean  @default(false) @map("is_best_product")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model ProductType {
  id        Int       @id @default(autoincrement())
  name      String
  category  String
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("product_types")
}

model Blog {
  id            Int      @id @default(autoincrement())
  title         String
  category      String
  image         String
  description   String   @db.Text
  author        String
  content       String   @db.Text
  publishedDate DateTime @default(now()) @map("published_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("blogs")
}

model HeroBanner {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hero_banners")
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AboutOffer {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("about_offers")
}

model AboutHistory {
  id          Int      @id @default(autoincrement())
  year        String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("about_histories")
}

model PromoCard {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("promo_cards")
}
